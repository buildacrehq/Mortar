# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
# Get from: Supabase → Settings → API → service_role key (NOT anon key)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ─── Backend URL ──────────────────────────────────────────────────────────────
# Set AFTER Vercel deploy — e.g. https://mortar-xyz.vercel.app
BACKEND_URL=https://your-vercel-url.vercel.app

# ─── Exotel (add Monday after signup at exotel.com) ───────────────────────────
# Get from: Exotel Dashboard → API Credentials
EXOTEL_SID=buildacre1
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_PHONE_BLR=08047285622
EXOTEL_PHONE_MYS=08047285622

# ─── Meta (add after marketing team gives access) ─────────────────────────────
# Get from: Meta Developers → Your App → Settings → Basic
META_APP_SECRET=your_meta_app_secret
# Any random string — you enter this same value in Meta webhook settings
META_VERIFY_TOKEN=mortar_meta_verify_2025
# Get from: Meta → Your Page → Access Tokens (long-lived page token)
META_PAGE_ACCESS_TOKEN=your_meta_page_access_token

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Shared secret between Apps Script and this backend
WEBHOOK_SECRET=mortar_webhook_secret_2025
# Get from Sheets URL: /spreadsheets/d/THIS_PART/edit
SHEETS_SPREADSHEET_ID=your_google_sheet_id

# ─── Firebase FCM (push notifications) ───────────────────────────────────────
# Get from: Firebase Console → Project Settings → Cloud Messaging → Server key
FCM_SERVER_KEY=your_firebase_server_key_here

# ─── Port (Vercel sets this automatically) ────────────────────────────────────
PORT=3000
